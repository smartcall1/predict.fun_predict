# =============================================
# Predict.fun AI Trading Bot 환경변수
# 원본: kalshi-ai-trading-bot → Predict.fun + Gemini Flash 포크
# =============================================

# === Predict.fun API (Discord에서 발급) ===
PREDICT_API_KEY=your_predict_api_key_here

# === BNB Chain 지갑 (LIVE 모드 전용) ===
PRIVATE_KEY=
WALLET_ADDRESS=

# === Gemini API (Google AI Studio에서 발급) ===
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# === Trading Configuration ===
LIVE_TRADING_ENABLED=false
INITIAL_BANKROLL=1000.0

# === AI Cost Control ===
DAILY_AI_COST_LIMIT=5.0

# === Logging ===
LOG_LEVEL=INFO
ENABLE_FILE_LOGGING=true
ENABLE_CONSOLE_LOGGING=true

# === Database ===
DATABASE_URL=sqlite:///trading_system.db

# === Telegram Notifications ===
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# === Performance Monitoring ===
ENABLE_PERFORMANCE_MONITORING=true
PERFORMANCE_LOG_INTERVAL_MINUTES=15
